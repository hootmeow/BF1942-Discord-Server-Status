# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# PostgreSQL connection to bf1942-stats-engine database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bf1942
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# How often to refresh all status messages (milliseconds)
POLL_INTERVAL_MS=60000

# Servers not seen in this many minutes are hidden from the embed
SERVER_STALE_MINUTES=10
